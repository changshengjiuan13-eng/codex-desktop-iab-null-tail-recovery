+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn turn_complete_preserves_agent_message_across_tool_follow_up() -> Result<()> {
+    let server = start_mock_server().await;
+    let tool_args = json!({
+        "command": "echo tool-result",
+        "timeout_ms": 1_000,
+    });
+    let responses = mount_sse_sequence(
+        &server,
+        vec![
+            sse(vec![
+                ev_response_created("resp-1"),
+                ev_assistant_message("msg-1", "intermediate answer"),
+                ev_function_call(
+                    "call-1",
+                    "shell_command",
+                    &serde_json::to_string(&tool_args)?,
+                ),
+                ev_completed("resp-1"),
+            ]),
+            sse(vec![ev_response_created("resp-2"), ev_completed("resp-2")]),
+        ],
+    )
+    .await;
+    let test = test_codex().build_with_auto_env(&server).await?;
+
+    test.codex
+        .submit(Op::UserInput {
+            items: vec![UserInput::Text {
+                text: "run the tool".to_string(),
+                text_elements: Vec::new(),
+            }],
+            final_output_json_schema: None,
+            responsesapi_client_metadata: None,
+            additional_context: Default::default(),
+            thread_settings: Default::default(),
+        })
+        .await?;
+
+    let completed = wait_for_event_match(&test.codex, |event| match event {
+        EventMsg::TurnComplete(completed) => Some(completed.clone()),
+        _ => None,
+    })
+    .await;
+    assert_eq!(
+        completed.last_agent_message.as_deref(),
+        Some("intermediate answer")
+    );
+    assert_eq!(responses.requests().len(), 2);
+    Ok(())
+}
