+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn partial_agent_message_followed_by_proxy_cyber_policy_error_is_aborted() -> Result<()> {
+    let server = start_mock_server().await;
+    let upstream_error = json!({
+        "error": {
+            "type": "invalid_request",
+            "code": "cyber_policy",
+            "message": "synthetic cyber policy error",
+            "param": null
+        }
+    })
+    .to_string();
+    let proxy_error = json!({
+        "error": {
+            "code": 400,
+            "message": upstream_error,
+            "type": "upstream_error"
+        }
+    });
+    let stream = format!(
+        "{}data: {proxy_error}\n\n",
+        sse(vec![
+            ev_response_created("resp-1"),
+            ev_message_item_added("msg-1", ""),
+            ev_output_text_delta("partial answer"),
+        ])
+    );
+    let response = mount_sse_sequence(&server, vec![stream]).await;
+    let test = test_codex().build_with_auto_env(&server).await?;
+
+    test.codex
+        .submit(Op::UserInput {
+            items: vec![UserInput::Text {
+                text: "start an answer".to_string(),
+                text_elements: Vec::new(),
+            }],
+            final_output_json_schema: None,
+            responsesapi_client_metadata: None,
+            additional_context: Default::default(),
+            thread_settings: Default::default(),
+        })
+        .await?;
+
+    let error = wait_for_event_match(&test.codex, |event| match event {
+        EventMsg::Error(error) => Some(error.clone()),
+        _ => None,
+    })
+    .await;
+    assert_eq!(error.message, "synthetic cyber policy error");
+    assert_eq!(error.codex_error_info, Some(CodexErrorInfo::CyberPolicy));
+
+    let aborted = wait_for_event_match(&test.codex, |event| match event {
+        EventMsg::TurnAborted(aborted) => Some(aborted.clone()),
+        _ => None,
+    })
+    .await;
+    assert_eq!(aborted.reason, TurnAbortReason::Interrupted);
+    assert_eq!(response.requests().len(), 1);
+    Ok(())
+}
