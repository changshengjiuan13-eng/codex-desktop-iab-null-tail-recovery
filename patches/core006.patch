+fn api_error_from_response_error(error: Error) -> ApiError {
+    if is_context_window_error(&error) {
+        ApiError::ContextWindowExceeded
+    } else if is_quota_exceeded_error(&error) {
+        ApiError::QuotaExceeded
+    } else if is_usage_not_included(&error) {
+        ApiError::UsageNotIncluded
+    } else if is_cyber_policy_error(&error) {
+        let message = cyber_policy_message(error.message);
+        ApiError::CyberPolicy { message }
+    } else if matches!(error.code.as_deref(), Some("invalid_prompt" | "bio_policy")) {
+        let message = error
+            .message
+            .unwrap_or_else(|| "Invalid request.".to_string());
+        ApiError::InvalidRequest { message }
+    } else if is_server_overloaded_error(&error) {
+        ApiError::ServerOverloaded
+    } else {
+        let delay = try_parse_retry_after(&error);
+        let message = error.message.unwrap_or_default();
+        ApiError::Retryable { message, delay }
+    }
+}
+
+fn response_error_from_stream_fields(
+    error: Option<Value>,
+    code: Option<String>,
+    message: Option<String>,
+) -> Option<Error> {
+    if let Some(error) = error
+        && let Some(parsed) = parse_stream_error_value(error)
+    {
+        return Some(parsed);
+    }
+
+    if let Some(message) = message.as_deref()
+        && let Some(parsed) = parse_embedded_stream_error(message)
+    {
+        return Some(parsed);
+    }
+
+    if code.is_some() || message.is_some() {
+        Some(Error {
+            r#type: None,
+            code,
+            message,
+            plan_type: None,
+            resets_at: None,
+        })
+    } else {
+        None
+    }
+}
+
+fn parse_stream_error_value(error: Value) -> Option<Error> {
+    let embedded = error
+        .as_str()
+        .or_else(|| error.get("message").and_then(Value::as_str));
+    if let Some(embedded) = embedded
+        && let Some(parsed) = parse_embedded_stream_error(embedded)
+    {
+        return Some(parsed);
+    }
+
+    serde_json::from_value::<Error>(error).ok()
+}
+
+fn parse_embedded_stream_error(message: &str) -> Option<Error> {
+    let payload = serde_json::from_str::<Value>(message).ok()?;
+    let error = payload.get("error").cloned().unwrap_or(payload);
+    serde_json::from_value::<Error>(error).ok()
+}
+
 fn is_context_window_error(error: &Error) -> bool {
     error.code.as_deref() == Some("context_length_exceeded")
 }
